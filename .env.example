# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lilia_db

# Firebase Admin SDK (get these from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Payments
PAYMENT_MODE=MANUAL
LILIA_PAYMENT_PHONE=+242000000000

# MTN Mobile Money (required when PAYMENT_MODE=SANDBOX or MTN_PRODUCTION)
MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=your-collection-subscription-key
MTN_MOMO_CALLBACK_URL=https://your-api.example.com/webhooks/mtn-momo
MTN_MOMO_WEBHOOK_SECRET=your-shared-webhook-secret
MTN_MOMO_API_KEY=your-api-key
MTN_MOMO_API_USER=your-api-user

# Mailtrap Email Service (optional - for welcome and promotional emails)
# Get your API token from: https://mailtrap.io/sending/domains (Settings > API Tokens)
MAILTRAP_API_TOKEN=your-mailtrap-api-token
MAILTRAP_SENDER_EMAIL=noreply@yourdomain.com
MAILTRAP_SENDER_NAME=Lilia Food

# Environment
NODE_ENV=development
PORT=3000

# Sentry — observabilité erreurs + performance (LFD-4 / CRIT-5)
# Laisser SENTRY_DSN vide en dev local => Sentry totalement désactivé.
# DSN : Sentry > Settings > Projects > lilia-backend > Client Keys (DSN)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Release tracking : en CI/Render, mettre le SHA du commit (ex: $RENDER_GIT_COMMIT)
SENTRY_RELEASE=
# Fraction de requêtes tracées / profilées (0.0 à 1.0). 0.1 = 10% recommandé en prod.
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
# Auth token pour l'upload des source maps (script `npm run sentry:sourcemaps`)
# Sentry > Settings > Account > Auth Tokens (scope: project:releases)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=lilia-backend
