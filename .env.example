# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lilia_db

# Firebase Admin SDK (get these from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Payments
PAYMENT_MODE=MANUAL
LILIA_PAYMENT_PHONE=+242000000000

# MTN Mobile Money (required when PAYMENT_MODE=SANDBOX or MTN_PRODUCTION)
MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=your-collection-subscription-key
MTN_MOMO_CALLBACK_URL=https://your-api.example.com/webhooks/mtn-momo
MTN_MOMO_WEBHOOK_SECRET=your-shared-webhook-secret
MTN_MOMO_API_KEY=your-api-key
MTN_MOMO_API_USER=your-api-user

# Mailtrap Email Service (optional - for welcome and promotional emails)
# Get your API token from: https://mailtrap.io/sending/domains (Settings > API Tokens)
MAILTRAP_API_TOKEN=your-mailtrap-api-token
MAILTRAP_SENDER_EMAIL=noreply@yourdomain.com
MAILTRAP_SENDER_NAME=Lilia Food

# Environment
NODE_ENV=development
PORT=3000

# Redis (BullMQ + Tracking + Idempotency)
REDIS_URL=redis://localhost:6379

# Notion integration (Operations / Wiki / CRM)
# 1. Crée une integration sur https://www.notion.so/my-integrations → copie le token
# 2. Dans Notion, crée une page (ex: "Lilia"), clique "..." → "Connections" → ajoute l'integration
# 3. Récupère l'ID de cette page (dernière partie de l'URL, 32 chars) → NOTION_WORKSPACE_PAGE_ID
# 4. Au premier démarrage (ou via POST /notion/bootstrap), la structure sera créée.
#    Les IDs renvoyés doivent être recopiés dans NOTION_ROOT_PAGE_ID + NOTION_DB_* pour persister.
NOTION_TOKEN=
NOTION_WORKSPACE_PAGE_ID=
NOTION_ROOT_PAGE_ID=
# Notion SDK v5+ : les vars ci-dessous stockent des DATA SOURCE IDs (pas des
# database IDs) — c'est ce que l'API utilise pour query + create page.
# Le bootstrap les extrait automatiquement de la réponse de databases.create.
NOTION_DB_ORDERS=
NOTION_DB_RESTAURANTS=
NOTION_DB_INCIDENTS=
