{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/lilia-app/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "apps/lilia-app/tsconfig.app.json",
    "webpack": true
  },
  "monorepo": true,
  "root": "apps/lilia-app",
  "projects": {
    "lilia-app": {
      "type": "application",
      "root": "apps/lilia-app",
      "entryFile": "main",
      "sourceRoot": "apps/lilia-app/src",
      "compilerOptions": {
        "tsConfigPath": "apps/lilia-app/tsconfig.app.json"
      }
    },
    "worker": {
      "type": "application",
      "root": "apps/worker",
      "entryFile": "main",
      "sourceRoot": "apps/worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/worker/tsconfig.app.json"
      }
    }
  }
}