// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}
datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique
  email       String   @unique
  nom        String?
  phone       String?
  imageUrl    String?
  role        Role     @default(CLIENT)
  driverStatus DriverStatus? // Statut du livreur, null pour les non-livreurs
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  restaurant  Restaurant?
  deliveries  Delivery[]
  cart        Cart?
  adresses   Adresses[] // Ajout de la relation aux adresses
  fcmTokens   FcmToken[]
  reviews     Review[]   // Avis laissés par l'utilisateur
  orders      Order[]    // Commandes passées par l'utilisateur
  promoUsages     PromoUsage[] @relation("UserPromoUsages")

  // Ajout recent 04/04/2026
  statusUser StatusUser   @default(ACTIVE)

  // Parrainage
  referralCode     String?  @unique          // code unique à partager
  referredByCode   String?                   // code du parrain utilisé à l'inscription
  referralRewarded Boolean  @default(false)  // vrai quand la récompense a été émise

  // Points de fidélité
  loyaltyPoints    Int      @default(0)
  loyaltyTransactions LoyaltyTransaction[]
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  points      Int                           // positif = gain, négatif = dépense
  reason      String                        // ex: "Commande #ABC123", "Récompense parrainage"
  orderId     String?                       // lien optionnel à la commande
  createdAt   DateTime @default(now())

  @@index([userId])
}

model FcmToken {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    String

  @@index([userId])
}

model Adresses {
  id         String    @id @default(cuid())
  rue        String
  ville      String
  etat       String?   // Région/État
  country    String
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  isDefault Boolean @default(false)
  quartier   Quartier? @relation(fields: [quartierId], references: [id])
  quartierId String?   // Référence au quartier pour le calcul des frais
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([quartierId])
}

model Restaurant {
  id                      String            @id @default(cuid())
  nom                     String
  adresse                 String
  phone                   String
  imageUrl                String?

  //Ajout 04/04
  latitude                Float?
  longitude               Float?

  owner                   User              @relation(fields: [ownerId], references: [id])
  ownerId                 String            @unique
  products                Product[]
  menuDuJour              MenuDuJour[]
  orders                  Order[]
  reviews                 Review[]          // Avis sur le restaurant
  specialties             Specialty[]       // Spécialités du restaurant
  banners                 Banner[]          // Bannières du restaurant

  // Statut d'activité (contrôlé par l'admin)
  isActive                Boolean           @default(true)  // Restaurant actif/désactivé par l'admin

  // Statut d'ouverture
  isOpen                  Boolean           @default(true)  // Restaurant ouvert/fermé
  manualOverride          Boolean           @default(false) // Si true, le cron ne modifie pas isOpen
  operatingHours          OperatingHours[]
  promoCodes      PromoCode[]  @relation("RestaurantPromoCodes")

  // Configuration de la livraison
  deliveryPriceMode       DeliveryPriceMode @default(FIXED)
  fixedDeliveryFee        Float             @default(1000)   // Prix fixe si mode FIXED
  deliveryZones           DeliveryZone[]    // Zones de livraison si mode ZONE_BASED
  estimatedDeliveryTimeMin Int              @default(15)    // Temps de livraison min (minutes)
  estimatedDeliveryTimeMax Int              @default(30)    // Temps de livraison max (minutes)
  minimumOrderAmount      Float             @default(0)     // Montant minimum de commande

  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
}

// Spécialités d'un restaurant (ex: "Pizza", "Sushi", "Burgers", "Africain")
model Specialty {
  id           String     @id @default(cuid())
  name         String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, name]) // Une spécialité unique par restaurant
  @@index([restaurantId])
}

model Category {
  id        String    @id @default(cuid())
  nom      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
model MenuDuJour {
  id             String         @id @default(cuid())
  nom            String
  description    String?
  imageUrl       String?
  prix           Float
  type           MenuType       @default(COMBO) // COMBO = multi-produits, PLAT_SPECIAL = plat unique
  ingredients    String?        // Composition du plat special (texte libre, ex: "Riz, poulet, legumes")
  stockQuotidien Int?           // Quantite disponible par jour (null = illimite)
  stockRestant   Int?           // Quantite restante aujourd'hui (null = illimite)
  dateDebut      DateTime       // Date et heure de début de validité du menu
  dateFin        DateTime       // Date et heure de fin de validité du menu
  isActive       Boolean        @default(true) // Permet de désactiver manuellement un menu
  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id])
  restaurantId   String
  products       MenuProduct[]  // Relation many-to-many avec Product
  orderItems     OrderItem[]
  cartItems      CartItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([restaurantId])
  @@index([dateDebut, dateFin]) // Index pour les requêtes par date
}

// Table de liaison pour la relation many-to-many entre Menu et Product
model MenuProduct {
  id           String      @id @default(cuid())
  menu         MenuDuJour  @relation(fields: [menuId], references: [id], onDelete: Cascade)
  menuId       String
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  ordre        Int         @default(0) // Ordre d'affichage dans le menu
  createdAt    DateTime    @default(now())

  @@unique([menuId, productId]) // Un produit ne peut être ajouté qu'une seule fois dans un menu
  @@index([menuId])
  @@index([productId])
}
model Product {
  id             String           @id @default(cuid())
  nom            String
  description    String?
  imageUrl       String?
  prixOriginal   Float
  stockQuotidien Int?             // Quantite disponible par jour (null = illimite)
  stockRestant   Int?             // Quantite restante aujourd'hui (null = illimite)
  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id])
  restaurantId   String
  category       Category?        @relation(fields: [categoryId], references: [id])
  categoryId     String?
  variants       ProductVariant[]
  menus          MenuProduct[]    // Relation many-to-many avec MenuDuJour
  orderItems     OrderItem[]
  cartItems      CartItem[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([restaurantId])
  @@index([categoryId])
}

model ProductVariant {
  id        String   @id @default(cuid())
  label      String?  // e.g., "30cl", "1.5L", "Normal", "Grand"
  prix     Float
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  cartItems   CartItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model Cart {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id])
  userId    String     @unique // Un utilisateur a un seul panier
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
model CartItem {
  id        String   @id @default(cuid())
  cart      Cart     @relation(fields: [cartId], references: [id])
  cartId    String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  menu      MenuDuJour?  @relation(fields: [menuId], references: [id])
  menuId    String?
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  variantId String
  quantite  Int
  createdAt DateTime @default(now())
  //04/04/2026 Nouveau champ — nullable au début pour ne pas casser l'existant
  itemKey String? // "productId:variantId:menuId|none"
  
  @@unique([cartId, variantId, menuId]) // Permet un même variant comme produit individuel ET dans un menu
  @@index([variantId])
  @@index([productId])
  @@index([menuId])
  @@index([cartId, itemKey]) // index de remplacement
}

// 04/04/2026 ÉTAPE 1 — Ajouter les nouveaux enums (non-breaking)
enum OrderLifecycleStatus {
  DRAFT           // Panier validé, pas encore payé
  CONFIRMED       // Paiement confirmé
  IN_PREPARATION  // Restaurant prépare
  READY           // Prêt pour livraison/retrait
  COMPLETED       // Livré ou retiré
  CANCELLED       // Annulé
}

model Order {
  id              String        @id @default(cuid())
  restaurant      Restaurant    @relation(fields: [restaurantId], references: [id])
  restaurantId    String
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  subTotal        Float         // Sous-total des articles
  deliveryFee     Float         // Frais de livraison (0 si retrait)
  serviceFee      Float   @default(0)   // ← nouveau : commission 10%
  total           Float                 // subTotal + deliveryFee + serviceFee        // Montant total (subTotal + deliveryFee)
  isDelivery      Boolean       @default(true)  // true = livraison, false = retrait au restaurant
  deliveryAddress String?       // Adresse de livraison (null si retrait)
  // 04/04/2026
  orderHistory      OrderHistory[] // Historique des changements de statut
  deliveryLatitude    Float?   // nouveau
  deliveryLongitude   Float?   // nouveau  
  deliveryQuartierId  String?  // nouveau — pour les frais de zone
  deleteCommande  Boolean       @default(false)
  paymentMethod   PaymentMethod // Méthode de paiement
  status          OrderStatus   @default(EN_ATTENTE)
  lifecycleStatus OrderLifecycleStatus? // nouveau, nullable
  paidAt          DateTime?     // Date de paiement
  notes           String?       // Notes optionnelles du client pour le restaurant
  contactPhone    String?       // Numéro de téléphone saisi lors de la commande
  items           OrderItem[]
  reviews         Review[]
  delivery        Delivery?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  Payment Payment[]
  promoCodeId     String?
  promoCode       PromoCode? @relation(fields: [promoCodeId], references: [id])
  discountAmount  Float      @default(0)  // montant déduit par le code promo

  @@index([promoCodeId])
  @@index([restaurantId])
  @@index([userId])
  @@index([status])           // ← manquait
  @@index([lifecycleStatus])  // ← nouveau
  @@index([createdAt])        // ← manquait
}

model OrderItem {
  id         String   @id @default(cuid())
  order      Order    @relation(fields: [orderId], references: [id])
  orderId    String
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  menu       MenuDuJour?  @relation(fields: [menuId], references: [id])
  menuId     String?
  variant    String   // e.g., "1.5L"
  quantite   Int
  prix      Float
  createdAt  DateTime @default(now())

  // 04/04/2026
  variantId      String?  // nullable pour les commandes existantes
  variantLabel   String?  // snapshot du label au moment de la commande
  snapshotPrice  Float?   // snapshot du prix au moment de la commande

  @@index([orderId])
  @@index([productId])
  @@index([menuId])
}
model OrderHistory {
  id         String   @id @default(cuid())
  order      Order    @relation(fields: [orderId], references: [id])
  orderId    String
  fromStatus OrderStatus
  toStatus   OrderStatus
  actionId    String  // "CLIENT", "RESTAURATEUR", "LIVREUR", "SYSTEM"
  reason      String? // Raison de l'annulation ou du changement de statut
  createdAt   DateTime @default(now())

  @@index([orderId])
}

enum DriverStatus {
  AVAILABLE
  ON_DELIVERY
  OFFLINE
}
model Delivery {
  id          String         @id @default(cuid())
  order       Order          @relation(fields: [orderId], references: [id])
  orderId     String         @unique
  deliverer   User?          @relation(fields: [delivererId], references: [id])
  delivererId String?
  status      DeliveryStatus @default(EN_ATTENTE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  estimatedArrival DateTime?   // ETA calculé
  pickedUpAt       DateTime?   // quand le livreur a pris la commande
  deliveredAt      DateTime?   // timestamp réel de livraison
  
  // Position dernière connue du livreur
  lastLatitude     Float?
  lastLongitude    Float?
  lastPositionAt   DateTime?
  locations        DeliveryLocation[]

  @@index([delivererId])
  @@index([status])    // ← manquait
}
// Nouvelle table — n'affecte pas l'existant
model DeliveryLocation {
  id          String   @id @default(cuid())
  deliveryId  String
  delivery    Delivery @relation(fields: [deliveryId], references: [id])
  latitude    Float
  longitude   Float
  accuracy    Float?   // précision GPS en mètres
  recordedAt  DateTime @default(now())
  
  @@index([deliveryId, recordedAt])
}
enum Role {
  ADMIN
  RESTAURATEUR
  LIVREUR
  CLIENT
}

enum StatusUser {
  INACTIVE
  ACTIVE
  BLOCKED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  MTN_MOMO
  AIRTEL_MONEY
}

enum OrderStatus {
  EN_ATTENTE
  PAYER
  EN_PREPARATION
  PRET
  EN_ROUTE
  LIVRER
  ANNULER
}

enum DeliveryStatus {
  EN_ATTENTE
  ASSIGNER
  EN_TRANSIT
  LIVRER
  ECHEC
}

model Payment {
  id                     String        @id @default(cuid())
  orderId                String
  amount                 Float
  currency               String        @default("XAF")
  phoneNumber            String
  status                 PaymentStatus @default(PENDING)
  provider               String        @default("MTN_MOMO")
  providerTransactionId  String?
  metadata               Json          @default("{}")
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  order                  Order         @relation(fields: [orderId], references: [id])

  @@map("payments")
  @@index([orderId])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum DayOfWeek {
  LUNDI
  MARDI
  MERCREDI
  JEUDI
  VENDREDI
  SAMEDI
  DIMANCHE
}

// Mode de tarification de la livraison pour chaque restaurant
enum DeliveryPriceMode {
  FIXED       // Prix fixe pour toutes les livraisons
  ZONE_BASED  // Prix selon le quartier/zone
}

enum MenuType {
  COMBO          // Menu compose de plusieurs produits existants
  PLAT_SPECIAL   // Plat special du jour (produit auto-cree)
}

// Modèle pour les avis et notes des clients
model Review {
  id           String     @id @default(cuid())
  rating       Int        // Note de 1 à 5
  comment      String?    // Commentaire optionnel
  user         User       @relation(fields: [userId], references: [id])
  userId       String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId String
  order        Order?     @relation(fields: [orderId], references: [id])
  orderId      String?    @unique // Optionnel: lié à une commande spécifique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@index([userId])
}

// Zones de livraison avec prix personnalisé par restaurant
model DeliveryZone {
  id           String     @id @default(cuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  zoneName     String     // Ex: "Zone 1", "Centre-ville", etc.
  fee          Float      // Prix de livraison pour cette zone
  quartiers    QuartierZone[] // Quartiers inclus dans cette zone
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
}

// Liste des quartiers de Brazzaville
model Quartier {
  id        String         @id @default(cuid())
  nom       String         @unique  // Ex: "Bacongo", "Poto-Poto", "Talangaï"
  ville     String         @default("Brazzaville")
  zones     QuartierZone[]
  adresses  Adresses[]
  createdAt DateTime       @default(now())
}

// Table de liaison entre quartiers et zones de livraison
model QuartierZone {
  id             String       @id @default(cuid())
  quartier       Quartier     @relation(fields: [quartierId], references: [id], onDelete: Cascade)
  quartierId     String
  deliveryZone   DeliveryZone @relation(fields: [deliveryZoneId], references: [id], onDelete: Cascade)
  deliveryZoneId String

  @@unique([quartierId, deliveryZoneId])
  @@index([quartierId])
  @@index([deliveryZoneId])
}

model Banner {
  id           String      @id @default(cuid())
  title        String?
  imageUrl     String
  description  String?
  linkUrl      String?
  isActive     Boolean     @default(true)
  displayOrder Int         @default(0)
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([restaurantId])
  @@index([isActive])
}

model OperatingHours {
  id           String     @id @default(cuid())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  dayOfWeek    DayOfWeek
  openTime     String     // "HH:mm"
  closeTime    String     // "HH:mm"
  isClosed     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, dayOfWeek])
  @@index([restaurantId])
  @@index([dayOfWeek])
}

enum DiscountType {
  FIXED           // montant fixe : -500 FCFA
  PERCENT         // pourcentage : -10%
  FREE_DELIVERY   // livraison gratuite
}

model PromoCode {
  id              String       @id @default(cuid())
  code            String       @unique  // "BIENVENUE500" — toujours uppercase
  description     String?      // affiché dans l'app : "500 FCFA offerts sur ta 1ère commande"

  discountType    DiscountType
  discountValue   Float        // 500 si FIXED, 10 si PERCENT (= 10%), 0 si FREE_DELIVERY
  maxDiscount     Float?       // plafond si PERCENT : max 2000 FCFA de réduction

  minOrderAmount  Float        @default(0)    // montant minimum pour activer le code
  maxUsageTotal   Int?         // null = illimité — ex: 100 pour une campagne limitée
  maxUsagePerUser Int          @default(1)    // 1 = 1 fois par utilisateur

  firstOrderOnly  Boolean      @default(false) // réservé aux nouveaux clients
  isActive        Boolean      @default(true)

  // Restriction par restaurant (null = toute la plateforme)
  restaurantId    String?
  restaurant      Restaurant?  @relation("RestaurantPromoCodes", fields: [restaurantId], references: [id])
  discountAmount  Float      @default(0)  // montant déduit par le code promo
  startsAt        DateTime     @default(now())
  expiresAt       DateTime?    // null = pas d'expiration

  usages          PromoUsage[]
  orders          Order[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([code])
  @@index([isActive, startsAt, expiresAt])
  @@index([restaurantId])
}

model PromoUsage {
  id          String     @id @default(cuid())
  promoCode   PromoCode  @relation(fields: [promoCodeId], references: [id])
  promoCodeId String
  userId      String
  user            User       @relation("UserPromoUsages", fields: [userId], references: [id])
  orderId     String     @unique  // 1 promo max par commande
  discountApplied Float           // montant réellement déduit (snapshot)
  usedAt      DateTime   @default(now())

  @@index([promoCodeId])
  @@index([userId])
}